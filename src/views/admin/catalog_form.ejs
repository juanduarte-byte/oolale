<div class="login-centered">
    <div class="kpi-card" style="max-width: 500px; width: 100%;">
        <div style="margin-bottom: 2rem;">
            <h2 style="font-size: 1.5rem; margin-bottom: 0.5rem; color: #fff;">
                <%= mode==='create' ? 'Crear' : 'Editar' %>
                    <%= entity %>
            </h2>
            <p style="color: var(--text-muted); font-size: 0.9rem;">
                <%= mode==='create' ? 'Agregar nuevo registro' : 'Modificando #' + item.id %>
            </p>
        </div>

        <form action="<%= formAction %>" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <!-- Campo Nombre (para Instrumentos) -->
            <% if (fields.includes('nombre')) { %>
                <div style="margin-bottom: 1.5rem;">
                    <label style="color: var(--text-muted); display: block; margin-bottom: 0.5rem;">Nombre</label>
                    <input type="text" name="nombre" value="<%= mode === 'edit' ? item.nombre : '' %>" required
                        style="width: 100%; padding: 12px; background: #000; border: 1px solid var(--border); border-radius: 8px; color: #fff; outline: none;">
                </div>
                <% } %>

                    <!-- Campo Descripción -->
                    <% if (fields.includes('descripcion')) { %>
                        <div style="margin-bottom: 1.5rem;">
                            <label
                                style="color: var(--text-muted); display: block; margin-bottom: 0.5rem;">Descripción</label>
                            <textarea name="descripcion" rows="3"
                                style="width: 100%; padding: 12px; background: #000; border: 1px solid var(--border); border-radius: 8px; color: #fff; outline: none; resize: vertical;"><%= mode === 'edit' && item.descripcion ? item.descripcion : '' %></textarea>
                        </div>
                        <% } %>

                            <!-- Campo Tipo -->
                            <% if (fields.includes('tipo')) { %>
                                <div style="margin-bottom: 1.5rem;">
                                    <label
                                        style="color: var(--text-muted); display: block; margin-bottom: 0.5rem;">Tipo</label>
                                    <input type="text" name="tipo"
                                        value="<%= mode === 'edit' && item.tipo ? item.tipo : '' %>"
                                        style="width: 100%; padding: 12px; background: #000; border: 1px solid var(--border); border-radius: 8px; color: #fff; outline: none;">
                                </div>
                                <% } %>

                            <!-- Campo Género Musical (para generos_perfil) -->
                            <% if (fields.includes('genre')) { %>
                                <div style="margin-bottom: 1.5rem;">
                                    <label style="color: var(--text-muted); display: block; margin-bottom: 0.5rem;">Género Musical</label>
                                    <input type="text" name="genre"
                                        value="<%= mode === 'edit' && item.genre ? item.genre : '' %>" required
                                        style="width: 100%; padding: 12px; background: #000; border: 1px solid var(--border); border-radius: 8px; color: #fff; outline: none;"
                                        placeholder="Ej: Rock, Jazz, Cumbia...">
                                </div>
                            <% } %>

                            <!-- Campo Familia (para gear_catalog) -->
                            <% if (fields.includes('familia')) { %>
                                <div style="margin-bottom: 1.5rem;">
                                    <label style="color: var(--text-muted); display: block; margin-bottom: 0.5rem;">Familia</label>
                                    <input type="text" name="familia"
                                        value="<%= mode === 'edit' && item.familia ? item.familia : '' %>"
                                        style="width: 100%; padding: 12px; background: #000; border: 1px solid var(--border); border-radius: 8px; color: #fff; outline: none;"
                                        placeholder="Ej: Guitarras Eléctricas, Percusión...">
                                </div>
                            <% } %>

                            <!-- Campo Comentario (para referencias/reseñas) -->
                            <% if (fields.includes('comentario')) { %>
                                <div style="margin-bottom: 1.5rem;">
                                    <label style="color: var(--text-muted); display: block; margin-bottom: 0.5rem;">Comentario</label>
                                    <textarea name="comentario" rows="3" required
                                        style="width: 100%; padding: 12px; background: #000; border: 1px solid var(--border); border-radius: 8px; color: #fff; outline: none; resize: vertical;"
                                        placeholder="Escribe el comentario de la reseña..."><%= mode === 'edit' && item.comentario ? item.comentario : '' %></textarea>
                                </div>
                            <% } %>

                            <!-- Campo Puntuación (para referencias/reseñas) -->
                            <% if (fields.includes('puntuacion')) { %>
                                <div style="margin-bottom: 1.5rem;">
                                    <label style="color: var(--text-muted); display: block; margin-bottom: 0.5rem;">Puntuación (1-5)</label>
                                    <input type="number" name="puntuacion" min="1" max="5" step="0.5"
                                        value="<%= mode === 'edit' && item.puntuacion ? item.puntuacion : '' %>"
                                        style="width: 100%; padding: 12px; background: #000; border: 1px solid var(--border); border-radius: 8px; color: #fff; outline: none;"
                                        placeholder="1-5">
                                </div>
                            <% } %>

                                    <div style="display: flex; gap: 10px; justify-content: flex-end; margin-top: 2rem;">
                                        <a href="<%= backPath %>" class="btn"
                                            style="background: rgba(255,255,255,0.1); color: #fff; text-decoration: none;">Cancelar</a>
                                        <button type="submit" class="btn btn-primary" style="padding: 12px 24px;">
                                            <%= mode==='create' ? 'Crear' : 'Guardar Cambios' %>
                                        </button>
                                    </div>
        </form>
    </div>
</div>